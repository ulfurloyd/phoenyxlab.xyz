---
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const isProjects =
	pathname === "/projects" ||
	pathname.startsWith("/projects/");
---

<nav>
	<a
		href="/"
		class={pathname === "/" ? "active" : ""}
	>home</a>
	<a
		href="/projects"
		class={isProjects ? "active" : ""}
	>projects</a>
	<a
		href="/now"
		class={pathname === "/now" ? "active" : ""}
	>now</a>
	<a
		href="/uses"
		class={pathname === "/uses" ? "active" : ""}
	>uses</a>
	<a
		href="/contact"
		class={pathname === "/contact" ? "active" : ""}
	>contact</a>
</nav>

<footer>
	<a
			href="https://astro.build"
			target="_blank"
			rel="noopener noreferrer"
	>built with astro
	</a>
</footer>
